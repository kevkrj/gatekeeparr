# Gatekeeper Configuration
# Copy this to .env and fill in your values

# ===================
# Server Configuration
# ===================
GATEKEEPER_HOST=0.0.0.0
GATEKEEPER_PORT=5000
GATEKEEPER_DEBUG=false
GATEKEEPER_SECRET_KEY=change-me-to-a-random-string

# External URL for callbacks (used by Mattermost buttons)
GATEKEEPER_URL=http://10.40.41.10:5000

# ===================
# AI Provider
# ===================
# Options: claude, ollama, openai, grok
AI_PROVIDER=claude

# API key (required for claude, openai, grok)
AI_API_KEY=your-api-key-here
# Or use provider-specific:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default model
# AI_MODEL=claude-sonnet-4-20250514

# For Ollama: Base URL of your Ollama instance
# AI_BASE_URL=http://localhost:11434

# ===================
# Jellyseerr
# ===================
JELLYSEERR_URL=http://jellyseerr:5055
JELLYSEERR_API_KEY=your-jellyseerr-api-key

# ===================
# Radarr
# ===================
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your-radarr-api-key

# ===================
# Sonarr
# ===================
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your-sonarr-api-key

# ===================
# Notifications
# ===================
# Mattermost incoming webhook URL
MATTERMOST_WEBHOOK=https://your-mattermost.com/hooks/xxx

# Discord webhook URL (optional)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx

# Generic webhooks (comma-separated, optional)
# GENERIC_WEBHOOKS=https://webhook1.com/hook,https://webhook2.com/hook

# ===================
# Database
# ===================
# SQLite (default):
DATABASE_URL=sqlite:////app/data/gatekeeper.db
# PostgreSQL (optional):
# DATABASE_URL=postgresql://user:pass@host:5432/gatekeeper
